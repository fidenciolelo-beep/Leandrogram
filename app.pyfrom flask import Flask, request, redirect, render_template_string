# ==================== FUNÇÕES ANTIGAS (manter) ====================
def salvar_acesso(usuario, senha):
    conn = get_db()
    cursor = conn.cursor()
    agora = datetime.now().strftime('%d/%m/%Y %H:%M:%S')
    cursor.execute('INSERT INTO acessos (usuario, senha, data) VALUES (?, ?, ?)',
                   (usuario, senha, agora))
    conn.commit()
    conn.close()

